      "description": "D",
      "inLanguage": "ru",
      "name": "Project",
      "publisher": {
        "@id": "https://example.com/#organization",
      },
      "url": "https://example.com",
    },
    {
      "@id": "https://example.com/ru#webpage",
      "@type": "WebPage",
      "description": "D",
      "inLanguage": "ru",
      "isPartOf": {
        "@id": "https://example.com/#website",
      },
      "mainEntity": {
        "@id": "https://example.com/ru#heritage-itemlist",
      },
      "name": "Project",
      "publisher": {
        "@id": "https://example.com/#organization",
      },
      "url": "https://example.com/ru",
    },
    {
      "@id": "https://example.com/ru#heritage-itemlist",
      "@type": "ItemList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "item": {
            "@type": "LandmarksOrHistoricalBuildings",
            "description": "В настоящее время объект является действующим православным храмом Ташкентской и Узбекистанской епархии. Он выполняет богослужебную, мемориальную, просветительскую и общинную функции, оставаясь одним из ключевых духовных центров Ферганской долины. Ранее здание было построено как кирха для лютеранской общины, а в советский период временно использовалось не по первоначальному назначению, а как складское помещение.",
            "image": "https://cdn.ruwiki.ru/commonswiki/files/thumb/5/55/Church_of_St._Sergiuy_Radonezhkogo_in_Fergana_02-01.jpg/600px-Church_of_St._Sergiuy_Radonezhkogo_in_Fergana_02-01.jpg",
            "name": "Храм преподобного Сергия Радонежского",
            "url": "https://example.com/ru/heritage/khram-sergiya-radonezhskogo",
          },
          "position": 1,
        },
        {
          "@type": "ListItem",
          "item": {
            "@type": "LandmarksOrHistoricalBuildings",
            "description": "Одним из интереснейших архитектурных памятников города является здание, которое в прошлом принадлежало пансиону Мариинского женского училища. Оно было построено в конце XIX века, приблизительно в 1877 году по проекту архитектора Э. А. Бруна. Первоначально здание использовалось как приходская школа. Позднее, в начале XX века, примерно в 1901-1903 годах, здание было перестроено и преобразовано в женскую гимназию с пансионом",
            "image": "https://upload.wikimedia.org/wikipedia/commons/2/2c/Fergana_oblast_building.jpg",
            "name": "Здание женской гимназии",
            "url": "https://example.com/ru/heritage/zhenskaya-gimnaziya",
          },
          "position": 2,
        },
        {
          "@type": "ListItem",
          "item": {
            "@type": "LandmarksOrHistoricalBuildings",
            "description": "Православная часовня, построенная в конце XIX века в русско-византийском стиле, ставшая важным архитектурным символом города. Часовня возведена из жженого кирпича, сохранила элементы классического храмового зодчества, отличается бело-розовыми тонами оформления, наличием открытых галерей и шатрового крыльца",
            "image": "https://upload.wikimedia.org/wikipedia/commons/2/2c/Fergana_oblast_building.jpg",
            "name": "Часовня во имя Святого благоверного князя Александра Невского",
            "url": "https://example.com/ru/heritage/chasovnya-aleksandra-nevskogo",
          },
          "position": 3,
        },
        {
          "@type": "ListItem",
          "item": {
            "@type": "LandmarksOrHistoricalBuildings",
            "description": "Архитектурное сооружение конца XIX — начала XX столетия, гарнизонный дом офицеров, построенный в стиле эклектики с элементами раннего русского классицизма.",
            "image": "https://upload.wikimedia.org/wikipedia/commons/2/2c/Fergana_oblast_building.jpg",
            "name": "Здание военного собрания (Дом офицеров)",
            "url": "https://example.com/ru/heritage/zdanie-voennogo-sobraniya-dom-oficerov",
          },
          "position": 4,
        },
        {
          "@type": "ListItem",
          "item": {
            "@type": "LandmarksOrHistoricalBuildings",
            "description": "Архитектурное сооружение конца XIX — начала XX столетия, военно-административный центр Нового Маргилана (ныне Фергана), построенное в стиле эклектики с элементами раннего русского классицизма.",
            "image": "https://upload.wikimedia.org/wikipedia/commons/f/f0/Fergana_Oblast_Administration.jpg",
            "name": "Здание военного губернатора",
            "url": "https://example.com/ru/heritage/gubernatorskiy-dom",
          },
          "position": 5,
        },
        {
          "@type": "ListItem",
          "item": {
            "@type": "LandmarksOrHistoricalBuildings",
            "description": "Памятник архитектуры начала XX века, построенный по проекту архитектора Г. М. Сваричевского. Здание отличается строгой симметрией, монументальными формами и элементами «кирпичного стиля» модерна. Центральную часть фасада выделяют крупные полуциркульные окна и выступающий объём. Сегодня в здании располагается административный корпус Ферганского государственного университета.",
            "image": "https://upload.wikimedia.org/wikipedia/commons/2/2c/Fergana_oblast_building.jpg",
            "name": "Здание мужской гимназии",
            "url": "https://example.com/ru/heritage/muzhskaya-gimnaziya",
          },
          "position": 6,
        },
      ],
      "name": "Project",
      "numberOfItems": 6,
    },
  ],
}
`;

