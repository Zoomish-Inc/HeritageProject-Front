          "@type": "ListItem",
          "item": {
            "@type": "LandmarksOrHistoricalBuildings",
            "description": "1879 yildan 1899 yilgacha bosqichma-bosqich qurilgan Farg'ona viloyatining asosiy ma'muriy binosi. Imperial Yangi Marg'ilonning me'moriy markazi.",
            "image": "https://placehold.co/1400x900/3d2b1f/f5ede0.webp?text=gubernatorskiy-dom-cover",
