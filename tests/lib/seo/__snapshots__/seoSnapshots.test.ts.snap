        "@id": "https://example.com/ru#heritage-itemlist",
      },
      "name": "Project",
      "publisher": {
        "@id": "https://example.com/#organization",
      },
      "url": "https://example.com/ru",
    },
    {
      "@id": "https://example.com/ru#heritage-itemlist",
      "@type": "ItemList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "item": {
            "@type": "LandmarksOrHistoricalBuildings",
            "description": "Одно из первых капитальных зданий Новой Маргиланы (Ферганы), возведённое в год основания города. Центр офицерской жизни гарнизона.",
            "image": "https://placehold.co/1400x900/3d2b1f/f5ede0.webp?text=zdanie-voennogo-sobraniya-dom-oficerov-cover",
            "name": "Здание военного собрания (Дом офицеров)",
            "url": "https://example.com/ru/heritage/zdanie-voennogo-sobraniya-dom-oficerov",
          },
          "position": 1,
        },
        {
          "@type": "ListItem",
          "item": {
            "@type": "LandmarksOrHistoricalBuildings",
            "description": "Главное административное здание Ферганской области, строившееся поэтапно с 1879 по 1899 год. Архитектурный центр имперского Нового Маргилана.",
            "image": "https://placehold.co/1400x900/3d2b1f/f5ede0.webp?text=gubernatorskiy-dom-cover",
            "name": "Здание военного губернатора",
            "url": "https://example.com/ru/heritage/gubernatorskiy-dom",
          },
          "position": 2,
        },
        {
          "@type": "ListItem",
          "item": {
            "@type": "LandmarksOrHistoricalBuildings",
            "description": "Первое светское женское учебное заведение Ферганской долины. Здание стало символом просвещения и «цивилизаторской миссии» в Средней Азии.",
            "image": "https://placehold.co/1400x900/3d2b1f/f5ede0.webp?text=zhenskaya-gimnaziya-cover",
            "name": "Здание женской гимназии (Дом культуры №1)",
            "url": "https://example.com/ru/heritage/zhenskaya-gimnaziya",
          },
          "position": 3,
        },
        {
          "@type": "ListItem",
          "item": {
            "@type": "LandmarksOrHistoricalBuildings",
            "description": "Небольшая православная часовня, возведённая в память о воинах, павших при завоевании Средней Азии. Единственный сохранившийся православный культовый объект города.",
            "image": "https://placehold.co/1400x900/3d2b1f/f5ede0.webp?text=chasovnya-aleksandra-nevskogo-cover",
            "name": "Часовня Святого Александра Невского",
            "url": "https://example.com/ru/heritage/chasovnya-aleksandra-nevskogo",
          },
          "position": 4,
        },
        {
          "@type": "ListItem",
          "item": {
            "@type": "LandmarksOrHistoricalBuildings",
            "description": "Главная православная церковь дореволюционной Ферганы. Крупнейший храм города, освящённый в память о преподобном Сергии Радонежском.",
            "image": "https://placehold.co/1400x900/3d2b1f/f5ede0.webp?text=khram-sergiya-radonezhskogo-cover",
            "name": "Храм Сергия Радонежского",
            "url": "https://example.com/ru/heritage/khram-sergiya-radonezhskogo",
          },
          "position": 5,
        },
        {
          "@type": "ListItem",
          "item": {
            "@type": "LandmarksOrHistoricalBuildings",
            "description": "Крупнейшее учебное заведение дореволюционной Ферганы. Здание с элементами стиля модерн стало последним значительным архитектурным сооружением имперского периода в городе.",
            "image": "https://placehold.co/1400x900/3d2b1f/f5ede0.webp?text=muzhskaya-gimnaziya-cover",
            "name": "Здание мужской гимназии",
            "url": "https://example.com/ru/heritage/muzhskaya-gimnaziya",
          },
          "position": 6,
        },
      ],
      "name": "Project",
      "numberOfItems": 6,
    },
  ],
}
`;

