          },
          "position": 4,
        },
        {
          "@type": "ListItem",
          "item": {
            "@type": "LandmarksOrHistoricalBuildings",
            "description": "Inqilobdan avvalgi Farg'onaning asosiy pravoslav cherkovi. Muqaddas Sergiy Radonezhskiy xotirasiga muqaddaslashtirilgan shahardagi eng yirik ibodatxona.",
            "image": "https://placehold.co/1400x900/3d2b1f/f5ede0.webp?text=khram-sergiya-radonezhskogo-cover",
